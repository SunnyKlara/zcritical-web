{
  "name": "@critical/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared contracts (Zod schemas, types, constants) between frontend and backend",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./events": "./src/events.ts",
    "./constants": "./src/constants.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "echo 'shared has noEmit; consumed via TS source'",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^8.57.1",
    "typescript": "^6.0.3",
    "vitest": "^2.1.5"
  }
}
