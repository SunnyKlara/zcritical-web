# =============================================================================
# Root .env.example — catalog of every variable used anywhere in the project.
# Per-package files live at `frontend/.env.local.example` and
# `backend/.env.example`. Copy those, not this one, when setting up locally.
# =============================================================================

# ---------- Backend (backend/.env) ----------
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas connection string (use mongodb+srv://... in production).
MONGODB_URI=mongodb://localhost:27017/critical

# JWT — generate each with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-me-with-another-openssl-rand-hex-32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Admin seed (first boot creates this user; rotate password on first login).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_EMAIL=admin@zcritical.co

# SMTP (lead / chat notifications). Leave blank to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Critical <no-reply@zcritical.co>"
NOTIFY_EMAIL=

# Sentry (backend).
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

# Logging
LOG_LEVEL=info

# ---------- Frontend (frontend/.env.local) ----------
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry (frontend — public DSN is safe to ship to browser).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_RELEASE=

# ---------- PayPal (added in M4 —交易闭环) ----------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
ORDER_EXPIRY_MINUTES=30

# ---------- Cloudflare R2 (added in M5 — 固件分发) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=critical-firmware
R2_PUBLIC_URL=
