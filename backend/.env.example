NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas connection string (use mongodb+srv://... in production).
MONGODB_URI=mongodb://localhost:27017/critical

# JWT — generate each with: openssl rand -hex 32
# Required for M3 (Admin auth), can be placeholder until then.
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-hex-32-bytes-minimum
JWT_REFRESH_SECRET=replace-me-with-another-openssl-rand-hex-32-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Symmetric key for AES-256-GCM at-rest encryption (TOTP secrets, future PII fields).
# REQUIRED in production. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Issuer label shown to administrators inside their authenticator app.
TOTP_ISSUER=Critical

# Admin seed (first boot creates this user; rotate password on first login).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_EMAIL=admin@zcritical.co

# SMTP (lead / chat notifications). Leave blank to disable — email is fire-and-forget.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Critical <no-reply@zcritical.co>"
NOTIFY_EMAIL=

# Sentry (backend). Leave blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

# Logging
LOG_LEVEL=info
